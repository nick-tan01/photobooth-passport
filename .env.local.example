# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase project URL (public, safe to expose client-side)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (public, safe to expose client-side; RLS enforces access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — SERVER-ONLY, bypasses RLS. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# PostHog project API key (public, safe to expose client-side)
NEXT_PUBLIC_POSTHOG_KEY=

# PostHog ingestion host, e.g. https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=

# Canonical site URL used for share links/OG tags, e.g. https://photoboothpassport.app
NEXT_PUBLIC_SITE_URL=
